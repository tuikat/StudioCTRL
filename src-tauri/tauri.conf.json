{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "StudioCTRL",
  "version": "0.1.0",
  "identifier": "io.github.tuikat.studioctrl",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "StudioCTRL",
        "width": 1320,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Video",
    "shortDescription": "Blackmagic camera controller",
    "longDescription": "StudioCTRL is a fast, beautiful desktop controller for the Blackmagic Micro Studio Camera 4K G2 and other Blackmagic cameras with the Camera Control REST API. Configure and switch between up to 8 cameras over the network."
  }
}
